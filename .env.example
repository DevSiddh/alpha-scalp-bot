# ================================================================
# Alpha-Scalp Bot – Environment Variables (.env)
# ================================================================

# ----- Binance Futures Exchange -----
BINANCE_API_KEY=your_real_key_here
BINANCE_SECRET=your_real_secret_here

# Demo trading on Binance (testnet balance, real market data)
# true  = use Binance demo-fapi (no real money)
# false = use real futures account (be careful)
BINANCE_DEMO_TRADING=false

# Local paper trading (no exchange calls, fully simulated)
# true  = simulate all orders locally using PAPER_STARTING_BALANCE
# false = use exchange (demo or live depending on BINANCE_DEMO_TRADING)
PAPER_TRADING_MODE=true
PAPER_STARTING_BALANCE=1000.0

# ----- Telegram Alerts -----
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# ----- Trading (optional overrides) -----
SYMBOL=BTC/USDT
TIMEFRAME=3m
LEVERAGE=2

# ----- Logging -----
LOG_LEVEL=INFO

# ----- Risk & Signal Config (P0-2 + S1) -----
SIGNAL_THRESHOLD=0.72
SCALP_MAX_HOLD_SECONDS=2700
MAX_CONCURRENT_TRADES=1
MAX_DAILY_LOSS_PCT=0.03
KELLY_FRACTION_CAP=0.10
KELLY_MIN_TRADES=300
WEIGHTS_LOCKED=true

MIN_POSITION_SIZE_USDT=6
MAX_POSITION_SIZE_USDT=15

ATR_SL_MULTIPLIER=1.5
ATR_TP_MULTIPLIER=3.0
ATR_PERIOD=14
MIN_REWARD_RISK_RATIO=1.8

# Volatility gate (ATR ratio vs 50-period mean)
ATR_RATIO_MAX=2.5
ATR_RATIO_MIN=0.5

# Session filter toggle
IS_SESSION_FILTER_ENABLED=true
