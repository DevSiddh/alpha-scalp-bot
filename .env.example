# ================================================================
# Alpha-Scalp Bot – Environment Variables
# ================================================================
# Copy this file to .env and fill in your credentials.
#   cp .env.example .env

# ----- Binance Futures Exchange -----
BINANCE_API_KEY= ur key
BINANCE_SECRET= ur key
BINANCE_DEMO_TRADING=true

# ----- Telegram Alerts -----
TELEGRAM_BOT_TOKEN= ur code
TELEGRAM_CHAT_ID=your_chat_id_here

# ----- Trading (optional overrides) -----
SYMBOL=BTC/USDT
TIMEFRAME=3m
LEVERAGE=2

# ----- Logging -----
LOG_LEVEL=INFO
# ----- P0-2: New Configuration Parameters -----
SIGNAL_THRESHOLD=0.72
SCALP_MAX_HOLD_SECONDS=900
MAX_CONCURRENT_TRADES=1
MAX_DAILY_LOSS_PCT=0.03
KELLY_FRACTION_CAP=0.10
MIN_POSITION_SIZE_USDT=6
MAX_POSITION_SIZE_USDT=15
ATR_SL_MULTIPLIER=1.5
ATR_TP_MULTIPLIER=3.0
ATR_PERIOD=14
MIN_REWARD_RISK_RATIO=1.8
ATR_RATIO_MAX=2.5
ATR_RATIO_MIN=0.5
IS_SESSION_FILTER_ENABLED=true
